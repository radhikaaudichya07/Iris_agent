# Copy to .env and fill in. Never commit .env.
SLACK_BOT_TOKEN=xoxb-your-bot-token          # Bot User OAuth Token (OAuth & Permissions page)
SLACK_APP_TOKEN=xapp-your-app-level-token    # App-Level Token with connections:write (Socket Mode)
GROQ_API_KEY=your-groq-key                   # free (no card): https://console.groq.com/keys
